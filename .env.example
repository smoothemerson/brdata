# Hardware profile — must be exactly one of: cpu | gpu-nvidia | gpu-amd
COMPOSE_PROFILES=cpu

OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://ollama:11434
MCP_BASE_URL=http://mcp:8001/mcp
IBGE_BASE_URL=https://servicodados.ibge.gov.br/api
MLFLOW_TRACKING_URI=http://mlflow:5000

# Required API protection for endpoints
# Clients must send header: X-API-Key: <value>
API_KEY=change-me
